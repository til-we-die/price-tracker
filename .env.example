# Конфигурация базы данных PostgreSQL

# Способ 1: Использование DSN
DB_DSN=postgres://user:password@host:port/dbname?sslmode=disable

# Способ 2: Альтернативный вариант с отдельными параметрами (выбрать одно)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=price_tracker

# API Aviasales (Travelpayouts)
# Получить токен можно здесь: https://travelpayouts.com/
AVI_TOKEN=your_aviasales_api_token_here

# SMTP настройки для email уведомлений

# SMTP сервер (пока только Gmail)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Кому отправлять уведомления
SMTP_TO=recipient_email@gmail.com
